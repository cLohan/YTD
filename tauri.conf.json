{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YTD Texture Optimizer",
  "version": "0.1.0",
  "identifier": "com.ytdoptimizer.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "YTD Texture Optimizer",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "wix": null
    },
    "icon": [
      "icons/icon.ico"
    ],
    "externalBin": [
      "sidecars/YtdCore/bin/Release/net8.0-windows/win-x64/publish/YtdCore"
    ],
    "resources": [
      "sidecars/YtdCore/bin/Release/net8.0-windows/win-x64/publish/YtdCore.exe",
      "sidecars/YtdCore/bin/Release/net8.0-windows/win-x64/publish/YtdCore.dll",
      "sidecars/YtdCore/bin/Release/net8.0-windows/win-x64/publish/YtdCore.deps.json",
      "sidecars/YtdCore/bin/Release/net8.0-windows/win-x64/publish/YtdCore.runtimeconfig.json",
      "sidecars/YtdCore/bin/Release/net8.0-windows/win-x64/publish/CodeWalker.Core.dll",
      "sidecars/YtdCore/bin/Release/net8.0-windows/win-x64/publish/SharpDX.dll",
      "sidecars/YtdCore/bin/Release/net8.0-windows/win-x64/publish/SharpDX.DXGI.dll",
      "sidecars/YtdCore/bin/Release/net8.0-windows/win-x64/publish/SharpDX.Direct3D11.dll",
      "sidecars/YtdCore/bin/Release/net8.0-windows/win-x64/publish/SharpDX.Mathematics.dll",
      "sidecars/YtdCore/bin/Release/net8.0-windows/win-x64/publish/SharpDX.Direct2D1.dll",
      "sidecars/YtdCore/bin/Release/net8.0-windows/win-x64/publish/SharpDX.D3DCompiler.dll",
      "sidecars/YtdCore/bin/Release/net8.0-windows/win-x64/publish/System.Drawing.Common.dll",
      "tools/encoders/texconv/texconv.exe",
      "tools/encoders/nvtt/nvidia-texture-tools-2.1.2-win/bin64/nvcompress.exe",
      "tools/encoders/nvtt/nvidia-texture-tools-2.1.2-win/bin64/nvdecompress.exe",
      "tools/encoders/nvtt/nvidia-texture-tools-2.1.2-win/bin64/nvtt.dll",
      "tools/encoders/magick/**"
    ]
  }
}
